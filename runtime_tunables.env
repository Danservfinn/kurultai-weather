# Runtime knobs for paper-only Polymarket weather engine.
# Safe for future goal-seeking proposals; no wallet, no live trading, no order placement.
# Cron schedule is managed by Hermes cronjob 4500a64f8da1; keep in sync with SCAN_INTERVAL_MINUTES.
SCAN_INTERVAL_MINUTES=15
DASHBOARD_POLL_SECONDS=30
SCAN_PAUSE_SECONDS=0.01
MARKET_METADATA_CACHE_TTL_SECONDS=900
FORECAST_CACHE_TTL_SECONDS=1800
OBSERVATION_CACHE_TTL_SECONDS=120
ORDERBOOK_CACHE_TTL_SECONDS=15
HTTP_TIMEOUT_SECONDS=8
SOURCE_BACKOFF_MINUTES=15
PER_SOURCE_DAILY_CALL_BUDGET=250
PAPER_SIZE_SHARES=2.0
EDGE_THRESHOLD=0.12
EDGE_THRESHOLD_TOUCHED=0.04
EDGE_THRESHOLD_AMBIGUOUS_STATION=0.18
MAX_SPREAD=0.08
MAX_SLIPPAGE=0.02
MIN_ENTRY=0.02
MAX_ENTRY=0.95
MIN_TOP_OF_BOOK_DEPTH=5.0
STALE_BOOK_MAX_AGE_SECONDS=30
MAX_POSITION_PCT=0.005
MAX_CITY_DATE_PCT=0.10
MAX_STATION_DATE_PCT=0.10
MAX_LADDER_GROUP_PCT=0.10
MAX_OPEN_EXPOSURE_PCT=0.20
