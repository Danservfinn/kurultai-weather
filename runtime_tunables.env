STATION_DISTANCE_PENALTY_PER_MILE=0.002
ELEVATION_DELTA_PENALTY_PER_100FT=0.002
UNKNOWN_STATION_EDGE_HAIRCUT=0.04
AMBIGUOUS_RULE_EDGE_HAIRCUT=0.04
MISSINGNESS_PENALTY=0.05
SOURCE_DISAGREEMENT_THRESHOLD_F=2.0
SOURCE_WEIGHT_OPEN_METEO=1.00
SOURCE_WEIGHT_NWS=0.00
SOURCE_WEIGHT_IEM=0.00
