ENABLE_WU=1
ENABLE_NWS=1
ENABLE_IEM=1
ENABLE_NCEI_DAILY=1
ENABLE_CDO=1
ENABLE_METEOSTAT=1
ENABLE_METAR_DIRECT=1
ENABLE_OM_MODELS=1
ENABLE_OM_HISTORICAL_FORECASTS=1
ENABLE_POLY_HISTORY=1
ALLOW_PAID_PROVIDER_FEATURES=0
